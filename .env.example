# ============== TW AI 节能器 - 环境变量配置 ==============
# 复制此文件为 .env 并修改相应配置

# ============== 服务版本 ==============
VERSION=latest
BUILD_TARGET=development  # development | production

# ============== MongoDB 配置 ==============
MONGODB_PORT=27017
MONGODB_USER=admin
MONGODB_PASSWORD=password123

# ============== Qdrant 配置 ==============
QDRANT_PORT=6333
QDRANT_API_TOKEN=
QDRANT_HTTPS_KEY=

# ============== API 服务配置 ==============
API_PORT=8080
LOG_LEVEL=INFO

# ============== Web UI 配置 ==============
WEB_PORT=3000

# ============== Nginx 配置 ==============
NGINX_PORT=80
HTTPS_PORT=443

# ============== 其他配置 ==============
TZ=Asia/Shanghai
